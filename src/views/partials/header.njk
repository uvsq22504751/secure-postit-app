<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ title }}</title>
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    {% if board and board.slug %}
      {% set currentBoardSlug = board.slug %}
    {% else %}
      {% set currentBoardSlug = 'main' %}
    {% endif %}
    <header class="topbar">
      <a class="brand" href="/{{ '' if currentBoardSlug == 'main' else currentBoardSlug }}">Secure Post-it</a>
      <nav class="topnav">
        {% if not currentUser %}
          <a href="/signup">Inscription</a>
        {% endif %}
        {% if currentUser and currentUser.permissions and currentUser.permissions.isAdmin %}
          <a href="/admin">Administration</a>
        {% endif %}
        {% if currentUser %}
          <form action="/logout" method="post">
            <input type="hidden" name="boardSlug" value="{{ currentBoardSlug }}" />
            <button type="submit">Deconnexion</button>
          </form>
        {% endif %}
      </nav>
    </header>
    {% if notice %}
      <p class="notice">{{ notice }}</p>
    {% endif %}
